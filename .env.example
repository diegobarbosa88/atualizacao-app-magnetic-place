# Environment Variables for app-magnetic

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Gemini AI API Key
# Get your key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Client Portal URL
VITE_CLIENT_PORTAL_URL=https://your-domain.com/?view=client_portal

# EmailJS Configuration
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID_NOTIF=your_emailjs_template_notif
VITE_EMAILJS_TEMPLATE_ID_PORTAL=your_emailjs_template_portal
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# CloudConvert API key (Word → PDF conversion in document templates)
# Get yours at: https://cloudconvert.com/dashboard/api/v2/keys
VITE_CLOUDCONVERT_API_KEY=your_cloudconvert_api_key_here
# Optional sandbox endpoint: https://api.sandbox.cloudconvert.com/v2
# VITE_CLOUDCONVERT_BASE_URL=https://api.cloudconvert.com/v2