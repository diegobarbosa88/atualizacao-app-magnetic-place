# Environment Variables for app-magnetic

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Gemini AI API Key
# Get your key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Client Portal URL
VITE_CLIENT_PORTAL_URL=https://your-domain.com/?view=client_portal

# EmailJS Configuration
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID_NOTIF=your_emailjs_template_notif
VITE_EMAILJS_TEMPLATE_ID_PORTAL=your_emailjs_template_portal
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# PDF.co API key (Word → PDF conversion in document templates)
# Get yours at: https://app.pdf.co/ (10,000 free credits on signup)
VITE_PDFCO_API_KEY=your_pdfco_api_key_here

# Gmail Invoice Import (Phase 17) — server-side only, set in Vercel dashboard, NOT prefixed with VITE_
# OAuth 2.0 credentials (from Google Cloud Console → Credentials → OAuth client ID)
GMAIL_CLIENT_ID=your_oauth_client_id_here
GMAIL_CLIENT_SECRET=your_oauth_client_secret_here
# Refresh token obtained via OAuth Playground (https://developers.google.com/oauthplayground)
# Scope used: https://mail.google.com/
GMAIL_REFRESH_TOKEN=your_refresh_token_here
# Supabase server-side (service role — different from the VITE_ anon key)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Shared secret to protect the import endpoint (any random string)
GMAIL_IMPORT_SECRET=your_random_secret_here
# Exposed to browser only to call the endpoint from the admin UI
VITE_GMAIL_IMPORT_SECRET=your_random_secret_here